# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and should never be committed.

# --- Stripe (required for checkout) ---
# Get this from https://dashboard.stripe.com/apikeys
# Use a test key (sk_test_...) for development.
STRIPE_SECRET_KEY=sk_test_...

# Get this from Stripe Dashboard > Developers > Webhooks after adding an
# endpoint pointing to https://yourdomain.com/api/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Transactional email (optional but recommended) ---
# Powers order confirmation emails (webhook) and the contact form.
# Get a key from https://resend.com — leave unset to skip emails (the site
# still works; submissions are just logged to the server console instead).
RESEND_API_KEY=

# --- Analytics (optional) ---
# Google Analytics 4 Measurement ID (starts with "G-"). Leave unset to
# disable analytics entirely.
NEXT_PUBLIC_GA_ID=

# --- Site URL (used for canonical URLs, sitemap, and JSON-LD) ---
# Set this to your real production domain once you have one.
NEXT_PUBLIC_SITE_URL=https://maxandlizzy.am

# --- Database (admin panel: products, stock, promo codes) ---
# Local dev: leave as-is, a SQLite file is created automatically.
# Production: use a real Postgres connection string (e.g. from Neon —
# neon.tech has a free tier). No schema changes needed to switch; see
# README "Admin panel & database" for the exact steps.
DATABASE_URL="file:./prisma/dev.db"

# Creates the first admin account the first time `npm run db:seed` runs.
# After logging in once, change the password from the admin panel.
ADMIN_BOOTSTRAP_EMAIL=admin@maxandlizzy.am
ADMIN_BOOTSTRAP_PASSWORD=changeme123

# --- Auto-translate (optional) ---
# Powers the "Auto-translate Armenian & Russian from English" button on
# /admin/products/new and edit pages, via the Google Cloud Translation API
# (chosen because it supports Armenian — most translation APIs, e.g. DeepL,
# don't). Get a key from https://console.cloud.google.com/apis/credentials
# after enabling the "Cloud Translation API" on a project — leave unset to
# hide the feature's effect (the button will show a setup error instead of
# translating). Has a small per-character cost after Google's free tier.
GOOGLE_TRANSLATE_API_KEY=
