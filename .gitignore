# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# local SQLite dev database (migrations/ IS committed — only the data file isn't)
/prisma/dev.db
/prisma/dev.db-journal

# typescript
*.tsbuildinfo
next-env.d.ts

# local Claude Code tool config (dev-server launch config, permission
# allowlist) — not part of the site, personal to this machine
/.claude/
