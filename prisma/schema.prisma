// Production database (Neon Postgres) — see README "Admin panel & database".
// The schema intentionally avoids SQLite- or Postgres-only features (native
// arrays, JSONB operators) so it works unchanged on either provider.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  name         String
  // "manager" (full access) or "cashier" (orders only — see lib/admin/permissions.ts)
  role         String         @default("manager")
  createdAt    DateTime       @default(now())
  sessions     AdminSession[]
}

model AdminSession {
  token       String    @id
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  adminUserId String
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@index([adminUserId])
}

model Product {
  id      String @id @default(cuid())
  slug    String @unique
  sku     String

  name   String
  nameHy String?
  nameRu String?

  shortDescription   String
  shortDescriptionHy String?
  shortDescriptionRu String?

  description   String
  descriptionHy String?
  descriptionRu String?

  priceAmd          Int
  compareAtPriceAmd Int?

  category    String
  subcategory String
  ageRange    String
  brand       String

  // JSON-encoded string[] / {src,alt}[] — kept as TEXT for SQLite/Postgres
  // portability rather than native array/JSON column types.
  materials    String
  safetyInfo   String
  images       String
  relatedSlugs String?

  inStock       Boolean @default(true)
  stockQuantity Int?

  featured   Boolean @default(false)
  bestseller Boolean @default(false)
  newArrival Boolean @default(false)

  dimensions       String?
  weightGrams      Int?
  careInstructions String?

  countryOfOrigin  String?
  packageContents  String?
  assemblyRequired Boolean?
  assemblyNote     String?
  supervisionNote  String?
  warranty         String?

  // "max" | "lizzy" | null — powers the Max's Pick / Lizzy's Pick badge.
  pickBy     String?
  pickNote   String?
  pickNoteHy String?
  pickNoteRu String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model PromoCode {
  id            String    @id @default(cuid())
  code          String    @unique
  percentOff    Int
  description   String
  descriptionHy String?
  descriptionRu String?
  active        Boolean   @default(true)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
}

model Customer {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model Order {
  id               String   @id @default(cuid())
  stripeSessionId  String   @unique
  customer         Customer @relation(fields: [customerId], references: [id])
  customerId       String
  // "pending" | "ready_for_pickup" | "shipped" | "completed" | "cancelled"
  status           String   @default("pending")
  // "pickup" | "delivery_yerevan" | "delivery_outside" | null (unknown / not collected)
  fulfillmentMethod String?
  totalAmd         Int
  promoCode        String?
  shippingAddress  String?
  customerName     String?
  customerPhone    String?
  giftWrap         Boolean  @default(false)
  giftMessage      String?
  items            OrderItem[]
  reviews          Review[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([customerId])
  @@index([status])
}

model OrderItem {
  id          String @id @default(cuid())
  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String
  productSlug String?
  productName String
  priceAmd    Int
  quantity    Int

  @@index([orderId])
}

model Review {
  id          String   @id @default(cuid())
  productSlug String
  // Links the review back to the order it was written from, proving it's a
  // verified purchase. Kept optional + onDelete:SetNull so deleting an order
  // doesn't cascade-delete reviews already published for that product.
  order       Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderId     String?
  authorName  String
  rating      Int
  title       String
  body        String
  // Reviews start hidden until a manager approves them in /admin/reviews,
  // so spam or inappropriate submissions never reach the storefront.
  approved    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([productSlug])
  @@index([orderId])
  @@index([approved])
}
